---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import bentotuiWordmarkLogo from "../../bentotui-wordmark-logo.png";

const quickStartCode = `package main

import (
	tea "charm.land/bubbletea/v2"
	"github.com/cloudboy-jh/bentotui"
	"github.com/cloudboy-jh/bentotui/core"
	"github.com/cloudboy-jh/bentotui/layout"
	"github.com/cloudboy-jh/bentotui/theme"
	"github.com/cloudboy-jh/bentotui/ui/containers/panel"
)

func main() {
	m := bentotui.New(
		bentotui.WithTheme(theme.Preset("catppuccin-mocha")),
		bentotui.WithPages(
			bentotui.Page("home", newHomePage),
		),
		bentotui.WithFooterBar(true),
	)

	p := tea.NewProgram(m)
	p.Run()
}

type homePage struct {
	root layout.Widget
}

func newHomePage() core.Page {
	sidebar := panel.New(panel.Title("Files"))
	main := panel.New(panel.Title("Editor"))
	
	return &homePage{
		root: layout.Horizontal(
			layout.Fixed(30, sidebar),
			layout.Flex(1, main),
		),
	}
}`;

const layers = [
  { name: "core", items: "shell, router, layout, focus, theme", desc: "Runtime orchestration" },
  { name: "containers", items: "panel, bar, dialog", desc: "Complex UI with borders" },
  { name: "widgets", items: "card, input, list, table, text", desc: "Content components" },
  { name: "primitives", items: "row, frame, surface", desc: "Low-level rendering" },
  { name: "styles", items: "theme → lipgloss", desc: "Style mapping" }
];
---

<BaseLayout>
  <header class="site-nav reveal" style="--delay: 40ms;">
    <a class="brand brand--wordmark" href="#top" aria-label="BentoTUI home">
      <img class="brand__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/docs">Docs</a>
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <button type="button" class="icon-button theme-toggle" data-theme-toggle aria-label="Switch theme">
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24"><path d="M21 14.25A8.25 8.25 0 1 1 9.75 3a7 7 0 1 0 11.25 11.25Z"/></svg>
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24"><path d="M12 17.25A5.25 5.25 0 1 0 12 6.75a5.25 5.25 0 0 0 0 10.5Z"/></svg>
      </button>
    </nav>
  </header>

  <main id="top" class="main-wrap">
    <section class="hero section-pad reveal" style="--delay: 120ms;">
      <img class="hero__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
      <p class="hero__subtitle">Build terminal apps without the boilerplate.</p>
      <p class="hero__pitch">
        BentoTUI is a framework for Bubble Tea that gives you layouts, routing, 
        focus management, and dialogs. Ship polished TUIs without rebuilding the same 
        architecture every time.
      </p>
      <div class="install-pill">
        <code>go get github.com/cloudboy-jh/bentotui</code>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 180ms;">
      <h2>Five layers. Clear separation.</h2>
      <p>
        BentoTUI organizes code into five layers. Each has a single responsibility. 
        Your app code sits at the top and composes the layers below.
      </p>
      
      <div class="layers-grid">
        {layers.map((layer, i) => (
          <div class="layer-card reveal" style={`--delay: ${200 + i * 40}ms`}>
            <div class="layer-header">
              <code class="layer-name">{layer.name}</code>
              <span class="layer-desc">{layer.desc}</span>
            </div>
            <div class="layer-items">{layer.items}</div>
          </div>
        ))}
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 400ms;">
      <h2>Get started</h2>
      <div class="code-frame">
        <Code lang="go" code={quickStartCode} />
      </div>
      <p class="section-p">
        <a href="/docs/architecture">Read the architecture guide</a> or 
        <a href="https://github.com/cloudboy-jh/bentotui">explore on GitHub</a>.
      </p>
    </section>
  </main>

  <footer class="site-footer reveal" style="--delay: 480ms;">
    <p>BentoTUI — Application framework for Bubble Tea</p>
    <div class="footer-links">
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <a href="/docs">Docs</a>
    </div>
  </footer>
</BaseLayout>

<style>
  .layers-grid {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .layer-card {
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    background: var(--surface);
  }
  
  .layer-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  
  .layer-name {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    background: transparent;
    border: none;
    padding: 0;
  }
  
  .layer-desc {
    font-size: 0.85rem;
    color: var(--body);
  }
  
  .layer-items {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.8rem;
    color: var(--muted);
  }
  
  .section-p {
    margin-top: 1rem;
    text-align: center;
  }
  
  .section-p a {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }
</style>
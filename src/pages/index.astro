---

<BaseLayout>
  <header class="site-nav reveal" style="--delay: 40ms;">
    <a class="brand brand--wordmark" href="#top" aria-label="BentoTUI home">
      <img class="brand__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/docs">Docs</a>
      <a href="/docs/colors">Colors</a>
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <button type="button" class="icon-button theme-toggle" data-theme-toggle aria-label="Switch theme">
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24"><path d="M21 14.25A8.25 8.25 0 1 1 9.75 3a7 7 0 1 0 11.25 11.25Z"/></svg>
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24"><path d="M12 17.25A5.25 5.25 0 1 0 12 6.75a5.25 5.25 0 0 0 0 10.5Z"/></svg>
      </button>
    </nav>
  </header>

  <main id="top" class="main-wrap">
    <section class="hero section-pad reveal" style="--delay: 120ms;">
      <img class="hero__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
      <p class="hero__subtitle">A copy-and-own terminal UI registry for Bubble Tea v2.</p>
      <p class="hero__pitch">
        BentoTUI 1.0 finalizes a composition-first component catalog and shifts fully into
        shipping runnable bento screen patterns. Run <code>bento add &lt;component&gt;</code>, copy
        source into your app, and build production TUIs without framework lock-in.
      </p>

      <div class="install-pill reveal" style="--delay: 200ms;">
        <code>go install github.com/cloudboy-jh/bentotui/cmd/bento@latest</code>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 240ms;">
      <h2>How it works</h2>
      <p>
        BentoTUI ships two source artifacts: <strong>components</strong> for reusable UI building blocks and
        <strong> bentos</strong> for complete screen patterns. You copy code directly into your project,
        keep ownership, and adapt behavior without framework lock-in.
      </p>
      
      <div class="code-frame">
        <Code lang="bash" code={quickStartCode} />
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 280ms;">
      <h2>Final Component Catalog (1.0)</h2>
      <p class="section-copy">The 1.0 catalog is locked for composition workflows: layout primitives, interaction helpers, and compatibility components for teams already shipping today.</p>

      <div class="components-grid">
        <article class="component-card component-card--current">
          <header class="component-card__head">
            <h3>Core layout/container</h3>
            <span class="component-count">4</span>
          </header>
          <ul class="component-list">
            <li><code>surface</code><span>Cell-buffer rendering with Ultraviolet</span></li>
            <li><code>panel</code><span>Titled and focusable content container</span></li>
            <li><code>bar</code><span>Status/nav bar with left and right slots</span></li>
            <li><code>dialog</code><span>Modal manager (Confirm, Custom, ThemePicker)</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Display helpers</h3>
            <span class="component-count">3</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>badge</code><span>Inline colored label</span></li>
            <li><code>kbd</code><span>Keyboard shortcut display</span></li>
            <li><code>wordmark</code><span>Large centered app identity</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Form/feedback</h3>
            <span class="component-count">3</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>select</code><span>Inline single-choice picker</span></li>
            <li><code>checkbox</code><span>Toggle boolean values</span></li>
            <li><code>progress</code><span>Progress bar with label support</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Advanced composition</h3>
            <span class="component-count">3</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>toast</code><span>Stacked auto-dismiss notifications</span></li>
            <li><code>tabs</code><span>Horizontal tab switcher</span></li>
            <li><code>separator</code><span>Horizontal or vertical rule</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Compatibility shipped</h3>
            <span class="component-count">4</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>input</code><span>Single-line input with accent border</span></li>
            <li><code>list</code><span>Scrollable log-style list</span></li>
            <li><code>table</code><span>Header and data rows</span></li>
            <li><code>text</code><span>Static styled label</span></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 320ms;">
      <h2>Live Theme Preview</h2>
      <p>Preview all built-in themes and Bento Rose in an app-shell simulation before selecting a preset for your project.</p>

      <div class="theme-preview" id="theme-preview" aria-live="polite">
        <div class="theme-preview__header">
          <div class="theme-preview__head-meta">
            <span class="theme-preview__label">Live Theme Preview</span>
            <span class="theme-preview__name" id="theme-preview-name">catppuccin-mocha</span>
          </div>
        </div>
        <div class="theme-shell" id="theme-shell">
          <div class="theme-preview__card">
            <div class="theme-preview__bar">
              <span class="theme-preview__dot"></span>
              <span>bento app-shell preview</span>
              <span class="theme-preview__spacer"></span>
              <button type="button" class="theme-picker__open" id="open-theme-dialog">Theme Picker</button>
              <span class="theme-picker__current" id="theme-picker-current">catppuccin-mocha</span>
            </div>

            <div class="theme-dialog" id="theme-dialog" aria-label="Theme picker" hidden>
              <header class="theme-dialog__header">
                <p>Theme Picker</p>
                <button type="button" class="theme-dialog__close" id="close-theme-dialog">Close</button>
              </header>
              <div class="theme-dialog__list" role="listbox" aria-label="Theme options">
                {liveThemes.map((theme, idx) => (
                  <button
                    type="button"
                    class={`theme-option${idx === 0 ? " is-active" : ""}`}
                    data-live-theme
                    data-theme-slug={theme.slug}
                    data-theme-name={theme.name}
                    data-theme-bg={theme.bg}
                    data-theme-surface={theme.surface}
                    data-theme-text={theme.text}
                    data-theme-body={theme.body}
                    data-theme-accent={theme.accent}
                    data-theme-codebg={theme.codebg}
                    data-theme-codeink={theme.codeink}
                    aria-selected={idx === 0 ? "true" : "false"}
                  >
                    {theme.name}
                  </button>
                ))}
              </div>
            </div>

            <div class="theme-preview__body">
              <p class="theme-preview__title">Dashboard panel</p>
              <p class="theme-preview__text">Compare tone, contrast, and border treatment across themes before finalizing your interface preset.</p>
            </div>
            <pre class="theme-preview__code"><code>$ bento add panel bar surface
$ bento init myapp
$ bento add badge tabs toast</code></pre>
          </div>
        </div>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 360ms;">
      <h2>Architecture</h2>
      <p>
        BentoTUI separates copied source from stable module imports. Components are copied into your
        codebase with <code>bento add</code>, while <code>theme</code>, <code>styles</code>, and <code>layout</code> remain standard package imports.
      </p>

      <p>
        Primitive wrappers are intentionally limited in 1.0. Use <code>charm.land/bubbles/v2/spinner</code> directly unless Bento adds clear composition value.
      </p>

      <div class="arch-flow">
        <article class="arch-layer">
          <span class="arch-step">01</span>
          <div>
            <strong>Your app code</strong>
            <span class="arch-note">Compose screens with copied components.</span>
          </div>
        </article>
        <article class="arch-layer arch-layer--highlight">
          <span class="arch-step">02</span>
          <div>
            <strong>registry/components/</strong>
            <span class="arch-note">Copy source into your app and own the implementation.</span>
          </div>
        </article>
        <article class="arch-layer">
          <span class="arch-step">03</span>
          <div>
            <strong>bentotui module deps</strong>
            <span class="arch-note">Stable imports: theme, styles, layout.</span>
          </div>
        </article>
        <article class="arch-layer">
          <span class="arch-step">04</span>
          <div>
            <strong>Charm stack</strong>
            <span class="arch-note">Built on Bubble Tea v2, Lip Gloss v2, and Ultraviolet.</span>
          </div>
        </article>
      </div>

      <p class="section-p">
        <a href="/docs/architecture">Read the architecture guide</a> or
        <a href="https://github.com/cloudboy-jh/bentotui">explore on GitHub</a>.
      </p>
    </section>

  </main>

  <footer class="site-footer reveal" style="--delay: 480ms;">
    <p>BentoTUI - Copy-and-own terminal UI registry for Bubble Tea v2</p>
    <div class="footer-links">
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <a href="/docs">Docs</a>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const options = Array.from(document.querySelectorAll("[data-live-theme]"));
      const preview = document.getElementById("theme-preview");
      const previewName = document.getElementById("theme-preview-name");
      const pickerCurrent = document.getElementById("theme-picker-current");
      const dialog = document.getElementById("theme-dialog");
      const openButton = document.getElementById("open-theme-dialog");
      const closeButton = document.getElementById("close-theme-dialog");
      if (!options.length || !preview || !previewName || !pickerCurrent) {
        return;
      }

      const themeStorageKey = "bento-theme-preset";

      function applyPreview(option) {
        const { themeBg, themeSurface, themeText, themeBody, themeAccent, themeCodebg, themeCodeink, themeName } = option.dataset;
        if (!themeBg || !themeSurface || !themeText || !themeBody || !themeAccent || !themeCodebg || !themeCodeink || !themeName) {
          return;
        }

        preview.style.setProperty("--preview-bg", themeBg);
        preview.style.setProperty("--preview-surface", themeSurface);
        preview.style.setProperty("--preview-text", themeText);
        preview.style.setProperty("--preview-body", themeBody);
        preview.style.setProperty("--preview-accent", themeAccent);
        preview.style.setProperty("--preview-codebg", themeCodebg);
        preview.style.setProperty("--preview-codeink", themeCodeink);
        previewName.textContent = themeName;
        pickerCurrent.textContent = themeName;
      }

      function setActiveOption(activeOption) {
        options.forEach((el) => {
          const isActive = el === activeOption;
          el.classList.toggle("is-active", isActive);
          el.setAttribute("aria-selected", String(isActive));
        });

        applyPreview(activeOption);
        localStorage.setItem(themeStorageKey, activeOption.getAttribute("data-theme-slug") || "catppuccin-mocha");
      }

      const storedTheme = localStorage.getItem(themeStorageKey);
      const storedOption = storedTheme
        ? options.find((option) => option.getAttribute("data-theme-slug") === storedTheme)
        : null;
      const initialOption = storedOption || options[0];
      setActiveOption(initialOption);

      options.forEach((option) => {
        option.addEventListener("click", () => {
          setActiveOption(option);
          if (dialog) {
            dialog.setAttribute("hidden", "");
          }
        });
      });

      if (openButton && dialog) {
        openButton.addEventListener("click", () => {
          const isHidden = dialog.hasAttribute("hidden");
          if (isHidden) {
            dialog.removeAttribute("hidden");
          } else {
            dialog.setAttribute("hidden", "");
          }
        });
      }

      if (closeButton && dialog) {
        closeButton.addEventListener("click", () => {
          dialog.setAttribute("hidden", "");
        });
      }

      document.addEventListener("click", (event) => {
        if (!dialog || dialog.hasAttribute("hidden")) {
          return;
        }
        const target = event.target;
        if (!(target instanceof Node)) {
          return;
        }
        if (!dialog.contains(target) && openButton && !openButton.contains(target)) {
          dialog.setAttribute("hidden", "");
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .section-copy {
    margin-top: 0.5rem;
    color: var(--body);
    max-width: 70ch;
  }

  .components-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }

  .component-card {
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--surface) 90%, white);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .component-card--current {
    border-color: color-mix(in srgb, var(--green) 48%, var(--border));
    background: color-mix(in srgb, var(--green) 8%, var(--surface));
  }

  .component-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--border);
  }

  .component-card__head h3 {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .component-count {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.75rem;
    color: var(--ink);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.14rem 0.45rem;
    background: var(--surface);
  }

  .component-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .component-list li {
    display: grid;
    grid-template-columns: minmax(0, auto) 1fr;
    gap: 0.5rem;
    align-items: baseline;
    padding: 0.36rem 0;
    border-bottom: 1px dashed color-mix(in srgb, var(--border) 82%, transparent);
    font-size: 0.9rem;
  }

  .component-list li:last-child {
    border-bottom: none;
  }

  .component-list code {
    color: color-mix(in srgb, var(--green) 60%, var(--ink));
    font-weight: 600;
  }

  .component-list--muted code {
    color: var(--muted);
  }

  .component-list span {
    color: var(--body);
  }

  .theme-picker__open {
    padding: 0.38rem 0.78rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    font-size: 0.78rem;
    font-family: "IBM Plex Mono", monospace;
    color: var(--ink);
    line-height: 1.2;
  }

  .theme-picker__current {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.73rem;
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    background: color-mix(in srgb, var(--surface) 90%, white);
  }

  .theme-dialog {
    width: min(500px, calc(100% - 1.6rem));
    border: 1px solid var(--border);
    border-radius: 0.72rem;
    padding: 0;
    background: color-mix(in srgb, var(--surface) 90%, white);
    color: var(--ink);
    box-shadow: 0 28px 46px -30px rgba(0, 0, 0, 0.65);
    position: absolute;
    top: 3.3rem;
    right: 0.8rem;
    z-index: 14;
  }

  .theme-dialog[hidden] {
    display: none;
  }

  .theme-dialog__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin: 0;
    padding: 0.75rem 0.85rem;
    border-bottom: 1px solid var(--border);
  }

  .theme-dialog__header p {
    margin: 0;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.76rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .theme-dialog__close {
    padding: 0.24rem 0.6rem;
    border-radius: 0.4rem;
    font-size: 0.74rem;
  }

  .theme-dialog__list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    padding: 0.85rem;
    max-height: 220px;
    overflow-y: auto;
  }

  .theme-option {
    text-align: left;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.74rem;
    padding: 0.45rem 0.55rem;
    border-radius: 0.46rem;
    border: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 92%, white);
    color: var(--ink);
  }

  .theme-option:hover {
    border-color: var(--green-light);
  }

  .theme-option.is-active {
    border-color: color-mix(in srgb, var(--green) 68%, var(--border));
    background: color-mix(in srgb, var(--green) 12%, var(--surface));
    color: color-mix(in srgb, var(--green) 78%, var(--ink));
  }

  .theme-preview {
    --preview-bg: #1e1e2e;
    --preview-surface: #313244;
    --preview-text: #cdd6f4;
    --preview-body: #bac2de;
    --preview-accent: #f38ba8;
    --preview-codebg: #11111b;
    --preview-codeink: #cdd6f4;
    margin-top: 1rem;
    padding: 1.15rem;
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    background: color-mix(in srgb, var(--surface) 90%, white);
    position: relative;
  }

  .theme-shell {
    position: relative;
  }

  .theme-preview__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;

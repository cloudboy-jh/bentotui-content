---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import bentotuiWordmarkLogo from "../../bentotui-wordmark-logo.png";

const quickStartCode = `# Copy components into your project
bento add input bar surface

# Run the starter app to see it in action
go run ./cmd/starter-app`;

const themes = [
  "catppuccin-mocha",
  "catppuccin-macchiato",
  "catppuccin-frappe",
  "dracula",
  "tokyo-night",
  "tokyo-night-storm",
  "nord",
  "gruvbox-dark",
  "monokai-pro",
  "kanagawa",
  "rose-pine",
  "ayu-mirage",
  "one-dark",
  "material-ocean",
  "github-dark"
];
---

<BaseLayout>
  <header class="site-nav reveal" style="--delay: 40ms;">
    <a class="brand brand--wordmark" href="#top" aria-label="BentoTUI home">
      <img class="brand__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/docs">Docs</a>
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <button type="button" class="icon-button theme-toggle" data-theme-toggle aria-label="Switch theme">
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24"><path d="M21 14.25A8.25 8.25 0 1 1 9.75 3a7 7 0 1 0 11.25 11.25Z"/></svg>
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24"><path d="M12 17.25A5.25 5.25 0 1 0 12 6.75a5.25 5.25 0 0 0 0 10.5Z"/></svg>
      </button>
    </nav>
  </header>

  <main id="top" class="main-wrap">
    <section class="hero section-pad reveal" style="--delay: 120ms;">
      <img class="hero__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
      <p class="hero__subtitle">A registry of copy-and-own terminal UI components.</p>
      <p class="hero__pitch">
        BentoTUI is a collection of components built on Bubble Tea v2 and Lip Gloss v2. 
        Run <code>bento add input</code> and the source lands in your project. 
        You own it — read it, modify it, delete what you don't need. 
        No framework lock-in, no lifecycle hooks, no "extend" API to learn.
      </p>
      
      <div class="warning-banner reveal" style="--delay: 160ms;">
        <strong>Early development</strong> - APIs and registry paths will change.
      </div>

      <div class="install-pill reveal" style="--delay: 200ms;">
        <code>go install github.com/cloudboy-jh/bentotui/cmd/bento@latest</code>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 240ms;">
      <h2>How it works</h2>
      <p>
        Two things live in this repo: <strong>components</strong> (atomic UI pieces you copy) 
        and <strong>bentos</strong> (pre-built layout compositions you copy wholesale).
      </p>
      
      <div class="code-frame">
        <Code lang="bash" code={quickStartCode} />
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 280ms;">
      <h2>Available Components</h2>
      <p class="section-copy">Grouped by what you can use now versus what is actively planned.</p>

      <div class="components-grid">
        <article class="component-card component-card--current">
          <header class="component-card__head">
            <h3>Available now</h3>
            <span class="component-count">8</span>
          </header>
          <ul class="component-list">
            <li><code>surface</code><span>Cell-buffer rendering with Ultraviolet</span></li>
            <li><code>bar</code><span>Status/nav bar with left and right slots</span></li>
            <li><code>input</code><span>Single-line input with accent border</span></li>
            <li><code>panel</code><span>Titled and focusable content container</span></li>
            <li><code>dialog</code><span>Modal manager (Confirm, Custom, ThemePicker)</span></li>
            <li><code>list</code><span>Scrollable log-style list</span></li>
            <li><code>table</code><span>Header and data rows</span></li>
            <li><code>text</code><span>Static styled label</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Tier 1 next</h3>
            <span class="component-count">4</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>badge</code><span>Inline colored label</span></li>
            <li><code>kbd</code><span>Keyboard shortcut display</span></li>
            <li><code>wordmark</code><span>Large centered app identity</span></li>
            <li><code>statusbar</code><span>Standalone registry bar</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Tier 2 and 3</h3>
            <span class="component-count">9</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>select</code><span>Inline single-choice picker</span></li>
            <li><code>checkbox</code><span>Toggle boolean values</span></li>
            <li><code>textarea</code><span>Multi-line input</span></li>
            <li><code>spinner</code><span>Loading indicator</span></li>
            <li><code>progress</code><span>Progress bar with label support</span></li>
            <li><code>command</code><span>Fuzzy command palette</span></li>
            <li><code>toast</code><span>Stacked auto-dismiss notifications</span></li>
            <li><code>tabs</code><span>Horizontal tab switcher</span></li>
            <li><code>separator</code><span>Horizontal or vertical rule</span></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 320ms;">
      <h2>15 Built-in Themes</h2>
      <p>
        Click a theme to update the snippet. Components should call <code>theme.CurrentTheme()</code>
        in each View render and should not cache the value.
      </p>
      <div class="themes-grid" role="group" aria-label="Built-in themes">
        {themes.map((name, idx) => (
          <button
            type="button"
            class={`theme-chip${idx === 0 ? " is-active" : ""}`}
            data-theme-preset
            data-theme-name={name}
            aria-pressed={idx === 0 ? "true" : "false"}
          >
            {name}
          </button>
        ))}
      </div>

      <div class="code-frame code-frame--theme" aria-live="polite">
        <pre class="theme-code"><code id="theme-snippet">theme.SetTheme("catppuccin-mocha")
t := theme.CurrentTheme()</code></pre>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 360ms;">
      <h2>Architecture</h2>
      <p>
        Components are copied into your project while core packages (<code>theme</code>, <code>styles</code>, <code>layout</code>)
        stay as normal imports from the bentotui module.
      </p>

      <div class="arch-flow">
        <article class="arch-layer">
          <span class="arch-step">01</span>
          <div>
            <strong>Your app code</strong>
            <span class="arch-note">Compose screens with copied components.</span>
          </div>
        </article>
        <article class="arch-layer arch-layer--highlight">
          <span class="arch-step">02</span>
          <div>
            <strong>registry/components/</strong>
            <span class="arch-note">surface, input, bar, dialog, panel, list, table, text</span>
          </div>
        </article>
        <article class="arch-layer">
          <span class="arch-step">03</span>
          <div>
            <strong>bentotui module deps</strong>
            <span class="arch-note">theme, styles, layout</span>
          </div>
        </article>
        <article class="arch-layer">
          <span class="arch-step">04</span>
          <div>
            <strong>Charm stack</strong>
            <span class="arch-note">Bubble Tea v2, Lip Gloss v2, Ultraviolet</span>
          </div>
        </article>
      </div>

      <p class="section-p">
        <a href="/docs/architecture">Read the architecture guide</a> or
        <a href="https://github.com/cloudboy-jh/bentotui">explore on GitHub</a>.
      </p>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 400ms;">
      <h2>Current Status</h2>
      <div class="status-list">
        <div class="status-item done">
          <span class="status-check">✓</span>
          <div>
            <strong>Starter app</strong> — Home screen with surface-backed rendering (v0.2)
          </div>
        </div>
        <div class="status-item active">
          <span class="status-check">→</span>
          <div>
            <strong>Tier 1 components</strong> — badge, kbd, wordmark, statusbar
          </div>
        </div>
        <div class="status-item">
          <span class="status-check">○</span>
          <div>
            <strong>home-screen bento</strong> — First bento, mirrors starter app
          </div>
        </div>
        <div class="status-item">
          <span class="status-check">○</span>
          <div>
            <strong>Tier 2 components</strong> — select, checkbox, textarea, spinner, progress
          </div>
        </div>
        <div class="status-item">
          <span class="status-check">○</span>
          <div>
            <strong>Remaining bentos</strong> — app-shell, dashboard, detail-view, form
          </div>
        </div>
        <div class="status-item">
          <span class="status-check">○</span>
          <div>
            <strong>Tier 3 components & CLI wiring</strong> — command, toast, tabs, bento init
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer reveal" style="--delay: 480ms;">
    <p>BentoTUI — The App framework for Bubble Tea</p>
    <div class="footer-links">
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <a href="/docs">Docs</a>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const chips = Array.from(document.querySelectorAll("[data-theme-preset]"));
      const snippet = document.getElementById("theme-snippet");
      if (!chips.length || !snippet) {
        return;
      }

      function setThemeSnippet(themeName) {
        snippet.textContent = `theme.SetTheme("${themeName}")\nt := theme.CurrentTheme()`;
      }

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          const themeName = chip.getAttribute("data-theme-name");
          if (!themeName) {
            return;
          }
          chips.forEach((el) => {
            el.classList.remove("is-active");
            el.setAttribute("aria-pressed", "false");
          });
          chip.classList.add("is-active");
          chip.setAttribute("aria-pressed", "true");
          setThemeSnippet(themeName);
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  .warning-banner {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid #f59e0b;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
    font-size: 0.95rem;
  }

  .section-copy {
    margin-top: 0.5rem;
    color: var(--body);
  }

  .components-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .component-card {
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--surface) 90%, white);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .component-card--current {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
    background: color-mix(in srgb, var(--accent) 6%, var(--surface));
  }

  .component-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--border);
  }

  .component-card__head h3 {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .component-count {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.75rem;
    color: var(--ink);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.14rem 0.45rem;
    background: var(--surface);
  }

  .component-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .component-list li {
    display: grid;
    grid-template-columns: minmax(0, auto) 1fr;
    gap: 0.5rem;
    align-items: baseline;
    padding: 0.36rem 0;
    border-bottom: 1px dashed color-mix(in srgb, var(--border) 82%, transparent);
    font-size: 0.85rem;
  }

  .component-list li:last-child {
    border-bottom: none;
  }

  .component-list code {
    color: var(--accent);
    font-weight: 600;
  }

  .component-list--muted code {
    color: var(--muted);
  }

  .component-list span {
    color: var(--body);
  }

  .themes-grid {
    margin: 1rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .theme-chip {
    padding: 0.33rem 0.72rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.78rem;
    font-family: "IBM Plex Mono", monospace;
    color: var(--muted);
    line-height: 1.2;
  }

  .theme-chip:hover {
    color: var(--ink);
    border-color: var(--accent-hover);
  }

  .theme-chip.is-active {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, var(--surface));
  }

  .code-frame--theme {
    margin-top: 0;
  }

  .theme-code {
    margin: 0;
    background: var(--code);
    color: var(--code-ink);
    border-radius: 0.8rem;
    border: 1px solid color-mix(in srgb, var(--code-border) 68%, var(--border));
    padding: 1rem;
    overflow-x: auto;
  }

  .theme-code code {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.86rem;
    line-height: 1.55;
    white-space: pre;
  }

  .arch-flow {
    margin-top: 1.3rem;
    display: grid;
    gap: 0.65rem;
  }

  .arch-layer {
    position: relative;
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.8rem;
    align-items: start;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--surface) 92%, white);
  }

  .arch-layer:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 1.48rem;
    bottom: -0.68rem;
    width: 1px;
    height: 0.68rem;
    background: color-mix(in srgb, var(--muted) 55%, var(--border));
  }

  .arch-layer--highlight {
    border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
    background: color-mix(in srgb, var(--accent) 8%, var(--surface));
  }

  .arch-step {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .arch-layer strong {
    display: block;
    color: var(--ink);
  }

  .arch-note {
    display: block;
    font-size: 0.84rem;
    color: var(--body);
    margin-top: 0.25rem;
  }

  .status-list {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .status-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--surface) 90%, white);
    border: 1px solid var(--border);
    border-radius: 0.6rem;
    font-size: 0.9rem;
  }

  .status-item.done {
    border-left: 4px solid #22c55e;
  }

  .status-item.active {
    border-left: 4px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, var(--surface));
  }

  .status-check {
    font-family: "IBM Plex Mono", monospace;
    font-weight: 600;
    min-width: 2.8rem;
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
  }

  .status-item.done .status-check {
    color: #22c55e;
  }

  .status-item.active .status-check {
    color: var(--accent);
  }

  .section-p {
    margin-top: 1.2rem;
    text-align: center;
  }

  .section-p a {
    text-decoration: underline;
    text-underline-offset: 0.14em;
  }

  @media (max-width: 680px) {
    .component-list li {
      grid-template-columns: 1fr;
      gap: 0.18rem;
    }

    .arch-layer {
      grid-template-columns: 2.5rem 1fr;
      gap: 0.6rem;
      padding: 0.8rem 0.85rem;
    }

    .arch-layer:not(:last-child)::after {
      left: 1.2rem;
    }

    .status-check {
      min-width: 2.3rem;
      font-size: 0.68rem;
    }
  }
</style>

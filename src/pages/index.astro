---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Code } from "astro:components";
import bentotuiWordmarkLogo from "../../bentotui-wordmark-logo.png";

const quickStartCode = `# Copy components into your project
bento add panel bar surface

# See available components and bentos
bento list

# Check your environment and setup
bento doctor

# Scaffold or compose from copy-and-own source
bento init myapp`;

const themePresets = [
  { name: "catppuccin-mocha", bg: "#1e1e2e", surface: "#313244", text: "#cdd6f4", accent: "#f38ba8", codebg: "#11111b", codeink: "#cdd6f4" },
  { name: "catppuccin-macchiato", bg: "#24273a", surface: "#363a4f", text: "#cad3f5", accent: "#f5bde6", codebg: "#181926", codeink: "#cad3f5" },
  { name: "catppuccin-frappe", bg: "#303446", surface: "#414559", text: "#c6d0f5", accent: "#eebebe", codebg: "#232634", codeink: "#c6d0f5" },
  { name: "dracula", bg: "#282a36", surface: "#343746", text: "#f8f8f2", accent: "#ff79c6", codebg: "#1f2029", codeink: "#f8f8f2" },
  { name: "tokyo-night", bg: "#1a1b26", surface: "#24283b", text: "#c0caf5", accent: "#7aa2f7", codebg: "#16161e", codeink: "#c0caf5" },
  { name: "tokyo-night-storm", bg: "#1f2335", surface: "#292e42", text: "#c0caf5", accent: "#9d7cd8", codebg: "#171b29", codeink: "#c0caf5" },
  { name: "nord", bg: "#2e3440", surface: "#3b4252", text: "#eceff4", accent: "#88c0d0", codebg: "#242933", codeink: "#eceff4" },
  { name: "gruvbox-dark", bg: "#282828", surface: "#3c3836", text: "#ebdbb2", accent: "#d79921", codebg: "#1d2021", codeink: "#ebdbb2" },
  { name: "monokai-pro", bg: "#2d2a2e", surface: "#403e41", text: "#fcfcfa", accent: "#ffd866", codebg: "#221f22", codeink: "#fcfcfa" },
  { name: "kanagawa", bg: "#1f1f28", surface: "#2a2a37", text: "#dcd7ba", accent: "#7e9cd8", codebg: "#16161d", codeink: "#dcd7ba" },
  { name: "rose-pine", bg: "#191724", surface: "#26233a", text: "#e0def4", accent: "#eb6f92", codebg: "#111019", codeink: "#e0def4" },
  { name: "ayu-mirage", bg: "#1f2430", surface: "#2b3245", text: "#cccac2", accent: "#ffb454", codebg: "#171b24", codeink: "#cccac2" },
  { name: "one-dark", bg: "#282c34", surface: "#353b45", text: "#abb2bf", accent: "#61afef", codebg: "#1f2329", codeink: "#abb2bf" },
  { name: "material-ocean", bg: "#0f111a", surface: "#1a1c25", text: "#a6accd", accent: "#89ddff", codebg: "#090b10", codeink: "#a6accd" },
  { name: "github-dark", bg: "#0d1117", surface: "#161b22", text: "#c9d1d9", accent: "#58a6ff", codebg: "#010409", codeink: "#c9d1d9" }
];
---

<BaseLayout>
  <header class="site-nav reveal" style="--delay: 40ms;">
    <a class="brand brand--wordmark" href="#top" aria-label="BentoTUI home">
      <img class="brand__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/docs">Docs</a>
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <button type="button" class="icon-button theme-toggle" data-theme-toggle aria-label="Switch theme">
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24"><path d="M21 14.25A8.25 8.25 0 1 1 9.75 3a7 7 0 1 0 11.25 11.25Z"/></svg>
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24"><path d="M12 17.25A5.25 5.25 0 1 0 12 6.75a5.25 5.25 0 0 0 0 10.5Z"/></svg>
      </button>
    </nav>
  </header>

  <main id="top" class="main-wrap">
    <section class="hero section-pad reveal" style="--delay: 120ms;">
      <img class="hero__logo" src={bentotuiWordmarkLogo.src} alt="BentoTUI" />
      <p class="hero__subtitle">A copy-and-own terminal UI registry for Bubble Tea v2.</p>
      <p class="hero__pitch">
        BentoTUI 1.0 finalizes a composition-first component catalog and shifts fully into
        shipping runnable bento screen patterns. Run <code>bento add &lt;component&gt;</code>, copy
        source into your app, and build production TUIs without framework lock-in.
      </p>

      <div class="install-pill reveal" style="--delay: 200ms;">
        <code>go install github.com/cloudboy-jh/bentotui/cmd/bento@latest</code>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 240ms;">
      <h2>How it works</h2>
      <p>
        Two things live in this repo: <strong>components</strong> (composition-ready UI pieces you copy)
        and <strong>bentos</strong> (full-screen runnable patterns you copy and adapt).
      </p>
      
      <div class="code-frame">
        <Code lang="bash" code={quickStartCode} />
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 280ms;">
      <h2>Final Component Catalog (1.0)</h2>
      <p class="section-copy">Composition-focused components with compatibility coverage for teams already shipping.</p>

      <div class="components-grid">
        <article class="component-card component-card--current">
          <header class="component-card__head">
            <h3>Core layout/container</h3>
            <span class="component-count">4</span>
          </header>
          <ul class="component-list">
            <li><code>surface</code><span>Cell-buffer rendering with Ultraviolet</span></li>
            <li><code>panel</code><span>Titled and focusable content container</span></li>
            <li><code>bar</code><span>Status/nav bar with left and right slots</span></li>
            <li><code>dialog</code><span>Modal manager (Confirm, Custom, ThemePicker)</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Display helpers</h3>
            <span class="component-count">3</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>badge</code><span>Inline colored label</span></li>
            <li><code>kbd</code><span>Keyboard shortcut display</span></li>
            <li><code>wordmark</code><span>Large centered app identity</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Form/feedback</h3>
            <span class="component-count">3</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>select</code><span>Inline single-choice picker</span></li>
            <li><code>checkbox</code><span>Toggle boolean values</span></li>
            <li><code>progress</code><span>Progress bar with label support</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Advanced composition</h3>
            <span class="component-count">3</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>toast</code><span>Stacked auto-dismiss notifications</span></li>
            <li><code>tabs</code><span>Horizontal tab switcher</span></li>
            <li><code>separator</code><span>Horizontal or vertical rule</span></li>
          </ul>
        </article>

        <article class="component-card">
          <header class="component-card__head">
            <h3>Compatibility shipped</h3>
            <span class="component-count">4</span>
          </header>
          <ul class="component-list component-list--muted">
            <li><code>input</code><span>Single-line input with accent border</span></li>
            <li><code>list</code><span>Scrollable log-style list</span></li>
            <li><code>table</code><span>Header and data rows</span></li>
            <li><code>text</code><span>Static styled label</span></li>
          </ul>
        </article>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 320ms;">
      <h2>15 Built-in Themes</h2>
      <p>
        Click a theme to generate a complete setup snippet. Components should call
        <code>theme.CurrentTheme()</code> in each View render and should not cache the value.
      </p>
      <div class="themes-grid" role="group" aria-label="Built-in themes">
        {themePresets.map((theme, idx) => (
          <button
            type="button"
            class={`theme-chip${idx === 0 ? " is-active" : ""}`}
            data-theme-preset
            data-theme-name={theme.name}
            data-theme-bg={theme.bg}
            data-theme-surface={theme.surface}
            data-theme-text={theme.text}
            data-theme-accent={theme.accent}
            data-theme-codebg={theme.codebg}
            data-theme-codeink={theme.codeink}
            aria-pressed={idx === 0 ? "true" : "false"}
          >
            {theme.name}
          </button>
        ))}
      </div>

      <div class="theme-preview" id="theme-preview" aria-live="polite">
        <div class="theme-preview__header">
          <span class="theme-preview__label">Live Theme Preview</span>
          <span class="theme-preview__name" id="theme-preview-name">catppuccin-mocha</span>
        </div>
        <div class="theme-preview__card">
          <div class="theme-preview__bar">
            <span class="theme-preview__dot"></span>
            <span>bento app-shell preview</span>
          </div>
          <div class="theme-preview__body">
            <p class="theme-preview__title">Dashboard panel</p>
            <p class="theme-preview__text">Pick a preset, copy the snippet, then render with <code>theme.CurrentTheme()</code> in each View.</p>
          </div>
          <pre class="theme-preview__code"><code>$ bento add panel bar surface
$ bento init myapp</code></pre>
        </div>
      </div>

      <div class="code-frame code-frame--theme" aria-live="polite">
        <div class="code-frame__top">
          <span class="code-title">Go setup snippet</span>
          <button type="button" class="copy-theme-snippet" id="copy-theme-snippet">Copy snippet</button>
        </div>
        <pre class="theme-code"><code id="theme-snippet">// Set once at startup
theme.SetTheme("catppuccin-mocha")

// Use current theme in every View render
t := theme.CurrentTheme()</code></pre>
      </div>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 360ms;">
      <h2>Architecture</h2>
      <p>
        Components are copied into your project while core packages (<code>theme</code>, <code>styles</code>, <code>layout</code>)
        stay as normal imports from the bentotui module.
      </p>

      <p>
        Primitive wrappers are intentionally limited in 1.0. Use <code>charm.land/bubbles/v2/spinner</code>
        directly unless Bento adds clear composition value.
      </p>

      <div class="arch-flow">
        <article class="arch-layer">
          <span class="arch-step">01</span>
          <div>
            <strong>Your app code</strong>
            <span class="arch-note">Compose screens with copied components.</span>
          </div>
        </article>
        <article class="arch-layer arch-layer--highlight">
          <span class="arch-step">02</span>
          <div>
            <strong>registry/components/</strong>
            <span class="arch-note">surface, input, bar, dialog, panel, list, table, text</span>
          </div>
        </article>
        <article class="arch-layer">
          <span class="arch-step">03</span>
          <div>
            <strong>bentotui module deps</strong>
            <span class="arch-note">theme, styles, layout</span>
          </div>
        </article>
        <article class="arch-layer">
          <span class="arch-step">04</span>
          <div>
            <strong>Charm stack</strong>
            <span class="arch-note">Bubble Tea v2, Lip Gloss v2, Ultraviolet</span>
          </div>
        </article>
      </div>

      <p class="section-p">
        <a href="/docs/architecture">Read the architecture guide</a> or
        <a href="https://github.com/cloudboy-jh/bentotui">explore on GitHub</a>.
      </p>
    </section>

    <section class="section-pad section-body reveal" style="--delay: 400ms;">
      <h2>1.0 Status Snapshot</h2>
      <div class="status-list">
        <div class="status-item done">
          <span class="status-check">✓</span>
          <div>
            <strong>Registry architecture</strong> — In place
          </div>
        </div>
        <div class="status-item active">
          <span class="status-check">✓</span>
          <div>
            <strong>CLI commands shipped</strong> — bento init, bento add, bento list, bento doctor
          </div>
        </div>
        <div class="status-item done">
          <span class="status-check">✓</span>
          <div>
            <strong>Core packages stable</strong> — theme, styles, layout
          </div>
        </div>
        <div class="status-item done">
          <span class="status-check">✓</span>
          <div>
            <strong>Component catalog finalized</strong> — 1.0 scope locked
          </div>
        </div>
        <div class="status-item active">
          <span class="status-check">→</span>
          <div>
            <strong>Execution focus now</strong> — ship broad, runnable bento screen patterns
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer reveal" style="--delay: 480ms;">
    <p>BentoTUI - Copy-and-own terminal UI registry for Bubble Tea v2</p>
    <div class="footer-links">
      <a href="https://github.com/cloudboy-jh/bentotui">GitHub</a>
      <a href="/docs">Docs</a>
    </div>
  </footer>

  <script is:inline>
    (() => {
      const chips = Array.from(document.querySelectorAll("[data-theme-preset]"));
      const snippet = document.getElementById("theme-snippet");
      const preview = document.getElementById("theme-preview");
      const previewName = document.getElementById("theme-preview-name");
      const copyButton = document.getElementById("copy-theme-snippet");
      if (!chips.length || !snippet || !preview || !previewName) {
        return;
      }

      const themeStorageKey = "bento-theme-preset";

      function setThemeSnippet(themeName) {
        snippet.textContent = `// Set once at startup\ntheme.SetTheme("${themeName}")\n\n// Use current theme in every View render\nt := theme.CurrentTheme()`;
      }

      function applyPreview(chip) {
        const { themeBg, themeSurface, themeText, themeAccent, themeCodebg, themeCodeink, themeName } = chip.dataset;
        if (!themeBg || !themeSurface || !themeText || !themeAccent || !themeCodebg || !themeCodeink || !themeName) {
          return;
        }

        preview.style.setProperty("--preview-bg", themeBg);
        preview.style.setProperty("--preview-surface", themeSurface);
        preview.style.setProperty("--preview-text", themeText);
        preview.style.setProperty("--preview-accent", themeAccent);
        preview.style.setProperty("--preview-codebg", themeCodebg);
        preview.style.setProperty("--preview-codeink", themeCodeink);
        previewName.textContent = themeName;
        setThemeSnippet(themeName);
      }

      function setActiveChip(activeChip) {
        chips.forEach((el) => {
          const isActive = el === activeChip;
          el.classList.toggle("is-active", isActive);
          el.setAttribute("aria-pressed", String(isActive));
        });

        applyPreview(activeChip);
        localStorage.setItem(themeStorageKey, activeChip.getAttribute("data-theme-name") || "catppuccin-mocha");
      }

      const storedTheme = localStorage.getItem(themeStorageKey);
      const storedChip = storedTheme
        ? chips.find((chip) => chip.getAttribute("data-theme-name") === storedTheme)
        : null;
      const initialChip = storedChip || chips[0];
      setActiveChip(initialChip);

      chips.forEach((chip) => {
        chip.addEventListener("click", () => {
          setActiveChip(chip);
        });
      });

      if (copyButton) {
        copyButton.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(snippet.textContent || "");
            copyButton.textContent = "Copied";
            setTimeout(() => {
              copyButton.textContent = "Copy snippet";
            }, 1200);
          } catch {
            copyButton.textContent = "Copy failed";
            setTimeout(() => {
              copyButton.textContent = "Copy snippet";
            }, 1200);
          }
        });
      }
    })();
  </script>
</BaseLayout>

<style>
  .section-copy {
    margin-top: 0.5rem;
    color: var(--body);
  }

  .components-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .component-card {
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--surface) 90%, white);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .component-card--current {
    border-color: color-mix(in srgb, var(--green) 48%, var(--border));
    background: color-mix(in srgb, var(--green) 8%, var(--surface));
  }

  .component-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--border);
  }

  .component-card__head h3 {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .component-count {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.75rem;
    color: var(--ink);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.14rem 0.45rem;
    background: var(--surface);
  }

  .component-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .component-list li {
    display: grid;
    grid-template-columns: minmax(0, auto) 1fr;
    gap: 0.5rem;
    align-items: baseline;
    padding: 0.36rem 0;
    border-bottom: 1px dashed color-mix(in srgb, var(--border) 82%, transparent);
    font-size: 0.85rem;
  }

  .component-list li:last-child {
    border-bottom: none;
  }

  .component-list code {
    color: color-mix(in srgb, var(--green) 60%, var(--ink));
    font-weight: 600;
  }

  .component-list--muted code {
    color: var(--muted);
  }

  .component-list span {
    color: var(--body);
  }

  .themes-grid {
    margin: 1rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .theme-chip {
    padding: 0.33rem 0.72rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.78rem;
    font-family: "IBM Plex Mono", monospace;
    color: var(--muted);
    line-height: 1.2;
  }

  .theme-chip:focus-visible {
    outline: 2px solid var(--green);
    outline-offset: 1px;
  }

  .theme-chip:hover {
    color: var(--ink);
    border-color: var(--green-light);
  }

  .theme-chip.is-active {
    border-color: var(--green);
    color: color-mix(in srgb, var(--green) 72%, var(--ink));
    background: color-mix(in srgb, var(--green) 11%, var(--surface));
  }

  .code-frame--theme {
    margin-top: 1rem;
  }

  .copy-theme-snippet {
    padding: 0.22rem 0.55rem;
    border-radius: 0.38rem;
    font-size: 0.72rem;
    line-height: 1.2;
  }

  .theme-preview {
    --preview-bg: #1e1e2e;
    --preview-surface: #313244;
    --preview-text: #cdd6f4;
    --preview-accent: #f38ba8;
    --preview-codebg: #11111b;
    --preview-codeink: #cdd6f4;
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--surface) 90%, white);
  }

  .theme-preview__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
  }

  .theme-preview__label,
  .theme-preview__name {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .theme-preview__label {
    color: var(--muted);
    text-transform: uppercase;
  }

  .theme-preview__name {
    color: var(--ink);
  }

  .theme-preview__card {
    border: 1px solid color-mix(in srgb, var(--preview-accent) 35%, #ffffff22);
    border-radius: 0.65rem;
    overflow: hidden;
    background: var(--preview-bg);
    color: var(--preview-text);
  }

  .theme-preview__bar {
    display: flex;
    align-items: center;
    gap: 0.48rem;
    padding: 0.42rem 0.65rem;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.73rem;
    background: color-mix(in srgb, var(--preview-surface) 88%, #00000022);
    border-bottom: 1px solid color-mix(in srgb, var(--preview-accent) 25%, #ffffff1f);
  }

  .theme-preview__dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--preview-accent);
  }

  .theme-preview__body {
    padding: 0.75rem 0.8rem 0.5rem;
    background: var(--preview-surface);
  }

  .theme-preview__title {
    margin: 0;
    font-family: "Outfit", sans-serif;
    font-size: 0.95rem;
    color: var(--preview-text);
  }

  .theme-preview__text {
    margin: 0.4rem 0 0;
    font-size: 0.84rem;
    color: color-mix(in srgb, var(--preview-text) 86%, #00000024);
  }

  .theme-preview__text code {
    border: 1px solid color-mix(in srgb, var(--preview-accent) 25%, #ffffff20);
    border-radius: 0.3rem;
    padding: 0.02rem 0.3rem;
    background: color-mix(in srgb, var(--preview-bg) 75%, #0000001f);
    color: var(--preview-accent);
  }

  .theme-preview__code {
    margin: 0;
    padding: 0.72rem 0.8rem;
    border-top: 1px solid color-mix(in srgb, var(--preview-accent) 20%, #ffffff1f);
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.78rem;
    line-height: 1.5;
    background: var(--preview-codebg);
    color: var(--preview-codeink);
  }

  .theme-code {
    margin: 0;
    background: var(--code);
    color: var(--code-ink);
    border-radius: 0.8rem;
    border: 1px solid color-mix(in srgb, var(--code-border) 68%, var(--border));
    padding: 1rem;
    overflow-x: auto;
  }

  .theme-code code {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.86rem;
    line-height: 1.55;
    white-space: pre;
  }

  .arch-flow {
    margin-top: 1.3rem;
    display: grid;
    gap: 0.65rem;
  }

  .arch-layer {
    position: relative;
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0.8rem;
    align-items: start;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    background: color-mix(in srgb, var(--surface) 92%, white);
  }

  .arch-layer:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 1.48rem;
    bottom: -0.68rem;
    width: 1px;
    height: 0.68rem;
    background: color-mix(in srgb, var(--muted) 55%, var(--border));
  }

  .arch-layer--highlight {

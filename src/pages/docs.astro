---
import BaseLayout from "../layouts/BaseLayout.astro";

const docPages = [
  {
    title: "Architecture",
    href: "/docs/architecture",
    description: "Composition-first architecture, component policy, and system design."
  },
  {
    title: "Roadmap",
    href: "/docs/framework-roadmap",
    description: "Component roadmap, priorities, and final 1.0 direction."
  },
  {
    title: "Color Guide",
    href: "/docs/colors",
    description: "Bento Coloring and Bento Rose palettes, contrast checks, and token exports."
  }
];
---

<BaseLayout title="BentoTUI Docs" description="BentoTUI documentation.">
  <header class="site-nav reveal" style="--delay: 40ms;">
    <a class="brand" href="/" aria-label="BentoTUI home">
      <span class="brand__name">BentoTUI</span>
      <span class="brand__badge">docs</span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/docs">Docs</a>
      <a href="/docs/colors">Colors</a>
      <a href="https://github.com/cloudboy-jh/bentotui" aria-label="BentoTUI GitHub repository">GitHub</a>
      <button type="button" class="icon-button theme-toggle" data-theme-toggle aria-label="Switch theme" title="Switch theme">
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M21 14.25A8.25 8.25 0 1 1 9.75 3a7 7 0 1 0 11.25 11.25Z"></path>
        </svg>
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M12 17.25A5.25 5.25 0 1 0 12 6.75a5.25 5.25 0 0 0 0 10.5Zm0-15a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V3a.75.75 0 0 1 .75-.75Zm0 16.5a.75.75 0 0 1 .75.75V21a.75.75 0 0 1-1.5 0v-1.5a.75.75 0 0 1 .75-.75Zm9-6.75a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75Zm-16.5 0a.75.75 0 0 1-.75.75H2.25a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75Zm12.864 6.864a.75.75 0 0 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 1.06-1.06l1.06 1.06Zm-10.608-10.608a.75.75 0 0 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 1.06-1.06l1.06 1.06Zm10.608-1.06a.75.75 0 0 1 0 1.06l-1.06 1.06a.75.75 0 1 1-1.06-1.06l1.06-1.06a.75.75 0 0 1 1.06 0ZM6.756 17.304a.75.75 0 0 1 0 1.06l-1.06 1.06a.75.75 0 0 1-1.06-1.06l1.06-1.06a.75.75 0 0 1 1.06 0Z"></path>
        </svg>
      </button>
    </nav>
  </header>

  <main class="main-wrap docs-main">
    <section class="docs-hero section-pad reveal" style="--delay: 100ms;">
      <h1>Documentation</h1>
      <p class="hero__subtitle">Architecture, roadmap, and color system guides for BentoTUI.</p>
    </section>

    <section class="docs-section section-pad reveal" style="--delay: 170ms;">
      <div class="docs-grid docs-grid--feature docs-grid--primary">
        {
          docPages.slice(0, 2).map((page) => (
            <article class="docs-card docs-card--feature">
              <h3><a href={page.href}>{page.title}</a></h3>
              <p>{page.description}</p>
            </article>
          ))
        }
      </div>

      <div class="docs-grid docs-grid--secondary">
        {
          docPages.slice(2).map((page) => (
            <article class="docs-card docs-card--feature docs-card--secondary">
              <h3><a href={page.href}>{page.title}</a></h3>
              <p>{page.description}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .docs-grid--feature {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    width: 100%;
    gap: 1.25rem;
  }

  .docs-grid--secondary {
    margin-top: 1.25rem;
    grid-template-columns: 1fr;
  }

  .docs-card--secondary {
    min-height: 148px;
  }

  .docs-card--feature {
    min-height: 210px;
    padding: 1.5rem 1.35rem;
    border-radius: 0.95rem;
    border-color: color-mix(in srgb, var(--green) 26%, var(--border));
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 92%, white) 0%, color-mix(in srgb, var(--surface) 86%, white) 100%),
      radial-gradient(130% 120% at 0% 0%, color-mix(in srgb, var(--green) 9%, transparent) 0%, transparent 65%);
  }

  .docs-card--feature h3 {
    font-size: 1.35rem;
    letter-spacing: 0.01em;
    font-family: "Fraunces", serif;
    margin-bottom: 0.5rem;
  }

  .docs-card--feature p {
    font-size: 1.08rem;
    line-height: 1.5;
    margin-top: 0;
  }
  
  @media (max-width: 680px) {
    .docs-grid--feature {
      grid-template-columns: 1fr;
    }

    .docs-card--feature {
      min-height: 140px;
      padding: 1rem;
    }
  }
</style>
